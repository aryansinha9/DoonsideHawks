# Doonside Hawks — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# Committee Portal password (used in /club-resources/committee-portal)
COMMITTEE_PORTAL_PASSWORD=change_me_please

# Resend API key for contact form email sending
# Get one from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender email address in your Resend account
RESEND_FROM_EMAIL=noreply@doonsidehawks.com.au

# Where contact form submissions are sent to
RESEND_TO_EMAIL=info@doonsidehawks.com.au
